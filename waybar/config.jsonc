		"custom/r_end",
		"custom/l_end",
		"hyprland/workspaces",
		"custom/r_end",
		"",
		"custom/padd"
	],
	"modules-center": [
		"custom/padd",
		"custom/l_end",
		"idle_inhibitor",
		"clock",
		"custom/r_end",
		"custom/padd"
	],
	"modules-right": [
