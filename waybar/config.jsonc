	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "¾░źö ",
			"deactivated": "’É║ "
		}
	},

	"clock": {
		"format": "{:%I:%M %p}",
		"format-alt": "{:%R ¾░āŁ %d┬Ę%m┬Ę%y}",
		"tooltip-format": "<tt>{calendar}</tt>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"on-scroll": 1,
			"on-click-right": "mode",
			"format": {
				"months": "<span color='#ffead3'><b>{}</b></span>",
				"weekdays": "<span color='#ffcc66'><b>{}</b></span>",
				"today": "<span color='#ff6699'><b>{}</b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},

	"tray": {
		"icon-size": 18,
		"spacing": 5
	},

	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 20
		},
		"format": "{icon} {capacity}%",
		"format-charging": "’ć” {capacity}%",
		"format-plugged": "’ć” {capacity}%",
		"format-alt": "{time} {icon}",
		"format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
	},

	"backlight": {
		"device": "intel_backlight",
		"format": "{icon} {percent}%",
		"format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"],
		"on-scroll-up": "brightnessctl set 1%+",
		"on-scroll-down": "brightnessctl set 1%-",
		"min-length": 6
	},

	"network": {
		// "interface": "wlp2*", // (Optional) To force the use of this interface
		"format-wifi": "¾░ż© {essid}",
		"format-ethernet": "¾▒ś¢ Wired",
		"tooltip-format": "¾▒ś¢ {ipaddr} ’ä╣ {bandwidthUpBytes} ’ä║ {bandwidthDownBytes}",
		"format-linked": "¾▒ś¢ {ifname} (No IP)",
		"format-disconnected": "’ü▒ Disconnected",
		"format-alt": "¾░ż© {signalStrength}%",
		"interval": 5
	},

	"bluetooth": {
		"format": "",
		"format-disabled": "", // an empty format will hide the module
		"format-connected": "’Ŗō {num_connections}",
		"tooltip-format": "’Ŗō {device_alias}",
		"tooltip-format-connected": "{device_enumerate}",
		"tooltip-format-enumerate-connected": "’Ŗō {device_alias}"
	},

	"pulseaudio": {
		"format": "{icon}",
		// "format": "{icon} {volume}",
		"format-muted": "Ņ¼ż ",
