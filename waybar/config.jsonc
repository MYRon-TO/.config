		"format-icons": {
			"headphone": "’Ćź",
			"hands-free": "’Ćź",
			"headset": "’Ćź",
			"phone": "’éĢ",
			"portable": "’éĢ",
			"car": "’å╣",
			"default": ["’Ć”", "’Ć¦", "’Ć©"]
		}
	},

