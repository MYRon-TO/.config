	"hyprland/workspaces": {
		"active-only": false,
		"all-outputs": true,
		"disable-scroll": false,
		"sort-by-name": true,
		"on-scroll-up": "hyprctl dispatch workspace -1",
		"on-scroll-down": "hyprctl dispatch workspace +1",
		"format": "{icon}",
		"on-click": "activate",
		"format-icons": {
			"urgent": "’ü¬",
			"active": "’åÆ",
			"default": "¾░¦×",
			"sort-by-number": true
		}
	},

	"custom/wallchange": {
		"format": "¾░åŖ ",
		"exec": "echo ; echo ¾░åŖ switch wallpaper",
		"on-click": "~/.config/.scripts/switchWallPaper.sh",
		// "on-click": "~/.config/hypr/scripts/swwwallpaper.sh -n",
		// "on-click-right": "~/.config/hypr/scripts/swwwallpaper.sh -p",
		// "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/swwwallselect.sh",
		// "interval": 86400, // once every day
		"tooltip": true
	},

	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
		"spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		// "on-scroll-up": "hyprctl dispatch workspace -1",
		// "on-scroll-down": "hyprctl dispatch workspace +1",
		// "ignore-list": ["Alacritty"],
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

