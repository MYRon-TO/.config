//   --// waybar config generated by wbarconfgen.sh //--   //

{
	// sourced from header module //

	"layer": "top",
	"position": "top",
	"mod": "dock",
	"height": 40,
	"exclusive": true,
	"passthrough": false,
	"gtk-layer-shell": true,

	// positions generated based on config.ctl //

	"modules-left": [
		"custom/padd",
		"custom/l_end",
		"custom/power",
